<Window x:Class="HotelBookingApp.Views.RoomCatalogWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Каталог номеров" Height="400" Width="600"
        WindowStartupLocation="CenterScreen">

    <Grid Margin="10">
        <DataGrid x:Name="RoomsGrid" AutoGenerateColumns="False" IsReadOnly="True">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="Auto"/>
                <DataGridTextColumn Header="Класс" Binding="{Binding Class}" Width="*"/>
                <DataGridTextColumn Header="Цена" Binding="{Binding Price}" Width="*"/>
                <DataGridTextColumn Header="Свободные места" Binding="{Binding FreePlaces}" Width="*"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Window>